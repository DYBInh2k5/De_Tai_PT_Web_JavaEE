# Sao chép nội dung này vào src/main/resources/application-local.properties
# (file application-local.properties không được commit — xem .gitignore)
#
# Hoặc đặt biến môi trường DB_PASSWORD trước khi chạy:
#   Windows: set DB_PASSWORD=MatKhauCuaBan
#   PowerShell: $env:DB_PASSWORD="MatKhauCuaBan"

spring.datasource.url=jdbc:sqlserver://localhost:1433;databaseName=ClassroomDB;encrypt=true;trustServerCertificate=true
spring.datasource.username=sa
spring.datasource.password=MAT_KHAU_SQL_SERVER_CUA_BAN

# SQL Server Express:
# spring.datasource.url=jdbc:sqlserver://localhost\\SQLEXPRESS;databaseName=ClassroomDB;encrypt=true;trustServerCertificate=true
